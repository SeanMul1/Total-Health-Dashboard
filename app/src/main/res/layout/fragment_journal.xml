<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Journal"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track your thoughts and mood"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="28dp"/>

        <!-- Mood Rating Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How is your mood today?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tv_mood_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😐"
                    android:textSize="48sp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_mood_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Neutral"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_gravity="center"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_mood_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 / 10"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"/>

                <SeekBar
                    android:id="@+id/seekbar_mood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="9"
                    android:progress="4"
                    android:progressTint="#9C27B0"
                    android:thumbTint="#9C27B0"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1"
                        android:textSize="11sp"
                        android:textColor="#BDBDBD"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="11sp"
                        android:textColor="#BDBDBD"
                        android:gravity="center"
                        android:layout_weight="1"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="10"
                        android:textSize="11sp"
                        android:textColor="#BDBDBD"
                        android:gravity="end"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Journal Entry Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What's on your mind?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/journal_input"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:hint="Write freely — this is just for you..."
                    android:gravity="top"
                    android:padding="0dp"
                    android:inputType="textMultiLine"
                    android:background="@null"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BDBDBD"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save_journal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Entry"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1A1A1A"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"/>

        <!-- Past entries section — inside the LinearLayout -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RECENT ENTRIES"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.1"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/poppins_semibold"/>

        <LinearLayout
            android:id="@+id/journal_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </LinearLayout>
</ScrollView>