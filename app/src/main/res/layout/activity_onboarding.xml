<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Your Goals 🎯"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"/>

        <!-- Research disclaimer card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFF3E0"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ A note on goal setting"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_semibold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="These are your personal health goals. We have provided sensible default ranges based on general guidelines, but everyone is different. We strongly encourage you to do your own research and consult a healthcare professional before setting targets — particularly for calories, heart rate and sleep. Your goals can be changed at any time in the Goals section."
                    android:textSize="13sp"
                    android:textColor="#BF360C"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- PHYSICAL section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHYSICAL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/poppins_semibold"/>

        <!-- Steps -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚶 Daily Steps"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 100 – 100,000 steps"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_steps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 10000"
                    android:text="10000"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Active Minutes -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️ Active Minutes"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 600 minutes"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_active"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 30"
                    android:text="30"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sleep -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😴 Sleep Hours"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 14 hours"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_sleep"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 8"
                    android:text="8"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Floors -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏢 Floors Climbed"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 500 floors"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_floors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 10"
                    android:text="10"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DIET section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DIET"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/poppins_semibold"/>

        <!-- Calories -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 Daily Calories"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 15,000 kcal"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_calories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 2000"
                    android:text="2000"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Protein -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥩 Daily Protein"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 500g"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_protein"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 50"
                    android:text="50"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Carbs -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍞 Daily Carbs"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 1,500g"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_carbs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 250"
                    android:text="250"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Fat -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥑 Daily Fat"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 500g"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_fat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 70"
                    android:text="70"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- MENTAL section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MENTAL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/poppins_semibold"/>

        <!-- Mood -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🙂 Target Mood Score"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 10"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_mood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 7"
                    android:text="7"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Journal days -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="32dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📓 Journal Days Per Week"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range: 1 – 7 days"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginBottom="8dp"/>
                <android.widget.EditText
                    android:id="@+id/et_journal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 5"
                    android:text="5"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:padding="12dp"
                    android:background="#F5F5F5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save button -->
        <Button
            android:id="@+id/btn_save_goals"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Let's Go! 🚀"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1A1A1A"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            app:cornerRadius="12dp"/>

        <TextView
            android:id="@+id/btn_skip_onboarding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use defaults and skip"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginBottom="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>
</ScrollView>