<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- Header + Search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diet"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/poppins_semibold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search and log what you eat"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/poppins_semibold"/>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/search_bar_bg"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <EditText
                android:id="@+id/et_food_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Type a food to search..."
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BDBDBD"
                android:background="@null"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:fontFamily="@font/poppins_semibold"/>

            <Button
                android:id="@+id/btn_search"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Search"
                android:textSize="13sp"
                android:backgroundTint="#1A1A1A"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp"/>

        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/search_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Frequent foods -->
            <TextView
                android:id="@+id/tv_frequent_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FREQUENT FOODS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:fontFamily="@font/poppins_semibold"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/frequent_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <!-- Search result card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_search_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_food_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A1A"
                                android:fontFamily="@font/poppins_semibold"/>

                            <TextView
                                android:id="@+id/tv_portion_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="per 150g"
                                android:textSize="12sp"
                                android:textColor="#9E9E9E"
                                android:fontFamily="@font/poppins_semibold"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_calories_big"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#FF9800"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                    <!-- Macros row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tv_protein"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textColor="#4CAF50"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tv_carbs"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textColor="#2196F3"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tv_fat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textColor="#FF5722"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                    <!-- Portion selector -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Portion size"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/poppins_semibold"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/portion_chips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Small (75g)"
                            android:textColor="@color/chip_text_selector"
                            android:checkable="true"
                            app:chipBackgroundColor="@drawable/chip_selector"
                            app:chipStrokeColor="#DDDDDD"
                            app:chipStrokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medium (150g)"
                            android:textColor="@color/chip_text_selector"
                            android:checked="true"
                            android:checkable="true"
                            app:chipBackgroundColor="@drawable/chip_selector"
                            app:chipStrokeColor="#DDDDDD"
                            app:chipStrokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_large"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Large (300g)"
                            android:textColor="@color/chip_text_selector"
                            android:checkable="true"
                            app:chipBackgroundColor="@drawable/chip_selector"
                            app:chipStrokeColor="#DDDDDD"
                            app:chipStrokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_custom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Custom"
                            android:textColor="@color/chip_text_selector"
                            android:checkable="true"
                            app:chipBackgroundColor="@drawable/chip_selector"
                            app:chipStrokeColor="#DDDDDD"
                            app:chipStrokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"/>

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Custom grams input -->
                    <LinearLayout
                        android:id="@+id/custom_portion_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp">

                        <EditText
                            android:id="@+id/et_custom_grams"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:hint="100"
                            android:inputType="number"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BDBDBD"
                            android:background="@drawable/search_bar_bg"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" grams"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_add_to_log"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="+ Add to Today's Log"
                        android:textSize="15sp"
                        android:backgroundTint="#1A1A1A"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="10dp"
                        android:fontFamily="@font/poppins_semibold"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Today's summary -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY'S SUMMARY"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_semibold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Calories"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tv_total_calories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 kcal"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#FF9800"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_total_macros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P: 0g  C: 0g  F: 0g"
                        android:textSize="13sp"
                        android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Food log -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOODS LOGGED"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_semibold"/>

            <LinearLayout
                android:id="@+id/food_log_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <TextView
                android:id="@+id/tv_empty_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No foods logged yet — search above to get started"
                android:textSize="14sp"
                android:textColor="#BDBDBD"
                android:gravity="center"
                android:padding="24dp"
                android:fontFamily="@font/poppins_semibold"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>