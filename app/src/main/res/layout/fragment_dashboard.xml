<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Welcome bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your overview"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Health"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"/>

            </LinearLayout>

            <!-- Welcome user - top right -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome,"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:id="@+id/tv_welcome_user"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User 👋"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_semibold"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Overall Health Score Hero Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A1A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overall Health Score"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:id="@+id/tv_overall_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="out of 100"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/poppins_semibold"/>

                <!-- Sub-score row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_sub_physical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"
                            android:fontFamily="@font/poppins_semibold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Physical"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="@font/poppins_semibold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#333333"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_sub_diet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FF9800"
                            android:fontFamily="@font/poppins_semibold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diet"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="@font/poppins_semibold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#333333"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_sub_mental"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#9C27B0"
                            android:fontFamily="@font/poppins_semibold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mental"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="@font/poppins_semibold"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Physical Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_physical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🏃"
                        android:textSize="28sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Physical"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tv_dash_steps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textSize="13sp"
                            android:textColor="#9E9E9E"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_dash_physical_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="score"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Diet Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_diet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🥗"
                        android:textSize="28sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diet"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tv_dash_calories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Log a food to see data"
                            android:textSize="13sp"
                            android:textColor="#9E9E9E"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_dash_diet_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#FF9800"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="score"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mental Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_mental"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🧠"
                        android:textSize="28sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mental"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tv_dash_mood"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Write a journal entry"
                            android:textSize="13sp"
                            android:textColor="#9E9E9E"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_dash_mental_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#9C27B0"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="score"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Goals card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_goals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🎯"
                        android:textSize="28sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Goals"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tv_dash_goals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View your targets"
                            android:textSize="13sp"
                            android:textColor="#9E9E9E"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_dash_goals_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="score"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="@font/poppins_semibold"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_view_history"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📅  View History"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#1A1A1A"
                android:textColor="#FFFFFF"
                android:layout_marginTop="12dp"
                app:cornerRadius="12dp"/>

            <!-- Data source note -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Physical: Fitbit (demo)  ·  Diet: Open Food Facts  ·  Mental: Journal"
                android:textSize="11sp"
                android:textColor="#BDBDBD"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins_semibold"/>

            <!-- Google users will see the option to set a password -->
            <TextView
                android:id="@+id/btn_set_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set a password for email login"
                android:textSize="13sp"
                android:textColor="#2196F3"
                android:gravity="center"
                android:layout_gravity="center"
                android:padding="8dp"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:fontFamily="@font/poppins_semibold"/>

            <!-- Logout -->
            <TextView
                android:id="@+id/btn_logout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log out"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:layout_gravity="center"
                android:padding="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:fontFamily="@font/poppins_semibold"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>