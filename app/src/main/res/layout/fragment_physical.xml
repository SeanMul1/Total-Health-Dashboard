<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Physical"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/poppins_semibold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's activity and wellness data"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_semibold"/>

        <TextView
            android:id="@+id/tv_data_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  NO DATA ENTERED YET  "
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:background="@drawable/badge_bg"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/poppins_semibold"/>

        <!-- Section: Activity -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVITY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_semibold"/>

        <!-- Row 1: Steps + Distance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👟" android:textSize="24sp"/>
                    <TextView android:id="@+id/tv_steps"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#4CAF50" android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="steps" android:textSize="11sp" android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Steps" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#1A1A1A" android:layout_marginTop="4dp"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📍" android:textSize="24sp"/>
                    <TextView android:id="@+id/tv_distance"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#00B0B9" android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="km" android:textSize="11sp" android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Distance" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#1A1A1A" android:layout_marginTop="4dp"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Row 2: Calories + Active Minutes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔥" android:textSize="24sp"/>
                    <TextView android:id="@+id/tv_calories_burned"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#FF9800" android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="kcal" android:textSize="11sp" android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Calories" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#1A1A1A" android:layout_marginTop="4dp"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⏱️" android:textSize="24sp"/>
                    <TextView android:id="@+id/tv_active_minutes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#4CAF50" android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="min" android:textSize="11sp" android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Active" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#1A1A1A" android:layout_marginTop="4dp"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Section: Heart -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HEART"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_semibold"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="❤️" android:textSize="24sp" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Resting Heart Rate" android:textSize="14sp"
                        android:textStyle="bold" android:textColor="#1A1A1A"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Normal range: 60–100 bpm" android:textSize="12sp"
                        android:textColor="#9E9E9E" android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
                <TextView android:id="@+id/tv_heart_rate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="20sp" android:textStyle="bold"
                    android:textColor="#F44336" android:fontFamily="@font/poppins_semibold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section: Sleep -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SLEEP"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_semibold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="😴" android:textSize="28sp"/>
                    <TextView android:id="@+id/tv_sleep"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="24sp" android:textStyle="bold"
                        android:textColor="#2196F3" android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="hours" android:textSize="12sp" android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sleep" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#1A1A1A" android:layout_marginTop="4dp"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="From Fitbit" android:textSize="11sp" android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⭐" android:textSize="28sp"/>
                    <TextView android:id="@+id/tv_sleep_score"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="24sp" android:textStyle="bold"
                        android:textColor="#2196F3" android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="/ 10" android:textSize="12sp" android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sleep Quality" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#1A1A1A" android:layout_marginTop="4dp"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Self rated" android:textSize="11sp" android:textColor="#9E9E9E"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Section: Wellness -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WELLNESS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9E9E9E"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_semibold"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🧘" android:textSize="28sp" android:layout_marginEnd="16dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Stress Level" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="#1A1A1A" android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1 = very stressed · 10 = very calm" android:textSize="12sp"
                        android:textColor="#9E9E9E" android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
                <TextView android:id="@+id/tv_stress"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="#4CAF50" android:fontFamily="@font/poppins_semibold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Fitbit Sync Button -->
        <Button
            android:id="@+id/btn_fitbit_sync"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Connect Fitbit"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#00B0B9"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"
            app:cornerRadius="12dp"/>

        <!-- Manual Entry Button -->
        <Button
            android:id="@+id/btn_manual_entry"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="+ Enter Today's Data Manually"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#1A1A1A"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>