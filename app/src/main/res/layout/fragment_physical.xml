            android:layout_height="wrap_content"
            android:text="Today's activity and wellness data"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_semibold"/>

        <TextView
